{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Project",
            "type": "shell",
            "command": "${workspaceFolder}/gradlew",
            "args": [
                "build"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$javac"]
        },
        {
            "label": "Run Text Game",
            "type": "shell",
            "command": "${workspaceFolder}/gradlew",
            "args": [
                "runTextGame"
            ],
            "group": "none"
        },
        {
            "label": "Run JavaFX GUI",
            "type": "shell",
            "command": "${workspaceFolder}/gradlew",
            "args": [
                "runGui"
            ],
            "group": "none"
        }
    ]
}
